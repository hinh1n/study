# app.py - 修改后的版本
import uvicorn
from fastapi import FastAPI, Request, Depends, HTTPException, status
from fastapi.responses import RedirectResponse
from fastapi.middleware.cors import CORSMiddleware
from fastapi.security import HTTPBasic, HTTPBasicCredentials
from fastapi.templating import Jinja2Templates
from register import Register
from functools import wraps
import secrets

# 创建安全实例
security = HTTPBasic()

# 创建 FastAPI 应用
app = FastAPI(title="Plombery Dashboard")

# 添加 CORS 中间件
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# 模板
templates = Jinja2Templates(directory="templates")

# 简单的用户验证（生产环境应使用数据库）
users_db = {
    "admin": "admin123",
    "user": "user123"
}

# 会话存储（生产环境应使用数据库或Redis）
sessions = {}

def check_login(username: str, password: str) -> bool:
    """验证用户名密码"""
    return users_db.get(username) == password

def create_session(username: str) -> str:
    """创建会话"""
    session_id = secrets.token_urlsafe(32)
    sessions[session_id] = {
        "username": username,
        "login_time": time.time()
    }
    return session_id

def verify_session(session_id: str) -> bool:
    """验证会话"""
    if session_id not in sessions:
        return False
    
    # 检查会话是否过期（24小时）
    session = sessions[session_id]
    if time.time() - session["login_time"] > 24 * 3600:
        del sessions[session_id]
        return False
    
    return True

# 登录依赖项
async def get_current_user(request: Request):
    """获取当前用户，如果未登录则重定向到登录页"""
    session_id = request.cookies.get("session_id")
    
    if not session_id or not verify_session(session_id):
        # 如果是 API 请求，返回 401
        if request.headers.get("accept") == "application/json":
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="Not authenticated"
            )
        # 否则重定向到登录页
        raise HTTPException(
            status_code=status.HTTP_307_TEMPORARY_REDIRECT,
            detail="Redirect to login",
            headers={"Location": "/login"}
        )
    
    return sessions[session_id]["username"]

# 登录页
@app.get("/login")
async def login_page(request: Request):
    """登录页面"""
    return templates.TemplateResponse("login.html", {"request": request})

@app.post("/login")
async def login(
    request: Request,
    credentials: HTTPBasicCredentials = Depends(security)
):
    """处理登录请求"""
    if not check_login(credentials.username, credentials.password):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Incorrect username or password",
            headers={"WWW-Authenticate": "Basic"},
        )
    
    # 创建会话
    session_id = create_session(credentials.username)
    
    # 设置cookie并重定向到主页
    response = RedirectResponse(url="/", status_code=303)
    response.set_cookie(
        key="session_id",
        value=session_id,
        httponly=True,
        max_age=24*3600,
        samesite="lax"
    )
    return response

@app.get("/logout")
async def logout(request: Request):
    """退出登录"""
    session_id = request.cookies.get("session_id")
    if session_id in sessions:
        del sessions[session_id]
    
    response = RedirectResponse(url="/login")
    response.delete_cookie("session_id")
    return response

# 保护主页
@app.get("/")
async def home(request: Request, username: str = Depends(get_current_user)):
    """需要登录才能访问的主页"""
    # 获取 Plombery 应用并返回
    from plombery import get_app
    
    # 这里可以返回自定义的仪表板
    return templates.TemplateResponse(
        "dashboard.html", 
        {
            "request": request,
            "username": username,
            "title": "Plombery Dashboard"
        }
    )

# 注册 Plombery 路由（在认证之后）
plombery_app = get_app()
app.mount("/api", plombery_app)
app.mount("/static", plombery_app)

# 注册管道
Register.register_pipeline()

if __name__ == '__main__':
    uvicorn.run(app, host="0.0.0.0", port=6338)
